# === Environment Variables ===
# Copy this file to .env and fill in the values

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gavai?schema=public"

# --- Redis ---
# Local dev (no Docker): use redis://localhost:6379
# Docker compose: use redis://:your-redis-password@redis:6379
REDIS_URL="redis://localhost:6379"
# Only needed if using password-protected Redis (Docker compose)
REDIS_PASSWORD=""

# --- Auth ---
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
JWT_REFRESH_SECRET="change-me-to-a-random-string-at-least-32-chars"
ADMIN_EMAIL="admin@gavai.dev"
ADMIN_PASSWORD="admin123"

# --- ML Sidecar ---
ML_SIDECAR_URL="http://localhost:8000"

# --- External APIs ---
GOOGLE_MAPS_KEY=""
BRIGHTDATA_API_KEY=""
GEMINI_API_KEY=""
AIML_API_KEY=""
XENDIT_SECRET_KEY=""
XENDIT_WEBHOOK_TOKEN=""

# --- Web (Next.js) ---
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""
NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"
WEB_URL="http://localhost:4200"

# --- Server ---
PORT=3000
NODE_ENV=development
